# Anthropic API key — never commit the real .env file
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional overrides
PORT=3001
ANTHROPIC_MODEL=claude-sonnet-4-6

# Comma-separated origins for CORS (defaults include common local dev URLs)
# ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8080,http://127.0.0.1:8080
